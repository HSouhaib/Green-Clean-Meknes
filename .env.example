# ═══════════════════════════════════════════════════════════════
# REQUIRED ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════

# JWT signing secret (generate a random 32+ character string)
# Example: openssl rand -base64 32
APP_SECRET=

# SQLite database file path
DATABASE_URL=local.db

# ═══════════════════════════════════════════════════════════════
# GOOGLE OAUTH (Required for authentication)
# ═══════════════════════════════════════════════════════════════
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create a project → APIs & Services → Credentials
# 3. Click "Create Credentials" → "OAuth client ID"
# 4. Application type: Web application
# 5. Add Authorized redirect URIs:
#    - http://localhost:5173/api/oauth/callback/google  (dev)
#    - https://yourdomain.com/api/oauth/callback/google  (production)
# 6. Copy Client ID and Client Secret below
# 7. First user to login can be set as admin via OWNER_UNION_ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════
# OPTIONAL
# ═══════════════════════════════════════════════════════════════

# Auto-promote first user to super_admin (set their Google sub ID after first login)
OWNER_UNION_ID=

# CORS origins (comma-separated, for production)
# Example: CORS_ORIGIN=https://greencleanmeknes.com
CORS_ORIGIN=
